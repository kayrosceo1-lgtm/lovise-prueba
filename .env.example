# WordPress Factory - Environment Variables
# Copy this file to .env and fill in your values

# === EasyPanel Deploy ===
EASYPANEL_DEPLOY_WEBHOOK=https://your-easypanel-server.com/webhook/deploy/xxxxx
EASYPANEL_HOST=your-server-ip-or-domain
EASYPANEL_SSH_USER=root
EASYPANEL_SSH_KEY_PATH=~/.ssh/id_rsa

# === WordPress (on EasyPanel) ===
WP_STAGING_URL=https://staging.your-domain.com
WP_STAGING_USER=admin
WP_STAGING_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# === Stitch MCP ===
# Option A: Google API Key (for remote HTTP MCP)
STITCH_API_KEY=your-google-api-key-from-stitch-settings

# Option B: Community CLI (no key needed, uses npx proxy)
# Leave STITCH_API_KEY empty to use the npx proxy

# === GitHub ===
GITHUB_REPO=your-username/your-repo-name
